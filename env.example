# Alpha Vantage API Key (required)
# Get free key at: https://www.alphavantage.co/
# Free tier: 100 API calls per day, 5 per minute
REACT_APP_ALPHAVANTAGE_KEY=demo

# Claude API Key (optional - for AI analysis)
# Get at: https://console.anthropic.com/
# Only needed if you want AI-powered educational analysis
# Remove this if you don't plan to use AI analysis
REACT_APP_CLAUDE_KEY=optional

# Note: 
# - Rename this file to .env.local for local development
# - Set these as environment variables in your deployment platform
# - Never commit actual API keys to version control
